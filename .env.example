# Supabase Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
TIMEZONE=Asia/Karachi

# Admin
ADMIN_SECRET=replace-with-a-long-random-secret
# TOTP secret for Google Authenticator (Base32 or hex — auto-detected)
# Generate with: node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
ADMIN_TOTP_SECRET=replace-with-your-totp-secret

# OTP Pepper (used for OTP hashing — should be different from ADMIN_SECRET)
OTP_PEPPER_SECRET=replace-with-another-long-random-secret
NEXT_PUBLIC_ADMIN_NAME=MeraDarzi Admin
NEXT_PUBLIC_ADMIN_WHATSAPP=920000000000
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Cron
CRON_SECRET=replace-with-a-long-random-secret

# PIN Encryption (32-byte hex key for AES-256-GCM)
# WARNING: Generate a NEW unique key for each environment. Do NOT reuse.
PIN_ENCRYPTION_KEY=replace-with-32-byte-hex-key-0123456789abcdef0123456789abcdef

# Cloudinary (optional)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Raast
NEXT_PUBLIC_RAAST_ID=03000000000
NEXT_PUBLIC_RAAST_NAME=Your Name
NEXT_PUBLIC_RAAST_BANK=Your Bank

# Email OTP via Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@example.com

# Rate Limiting via Upstash
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Web Push (VAPID)
# Generate fresh keys for each environment with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-your-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com