# ── Supabase Database ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used for: API CORS, redirect URLs, WhatsApp links
# Production: https://your-domain.com
# Development: http://localhost:3000

# ── Secrets (REQUIRED) ────────────────────────────────────────────────────────
ADMIN_SECRET=replace-with-a-long-random-secret
# Used for: Admin HMAC session signing, login authentication
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SIGNING_SECRET=replace-with-a-long-random-secret
# Used for: Member session token HMAC signing (session.ts)
# IMPORTANT: Must be DIFFERENT from ADMIN_SECRET. Generate fresh.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

ADMIN_TOTP_SECRET=replace-with-your-totp-secret
# Used for: Admin 2FA via Google Authenticator
# Generate a hex secret (app auto-converts hex → Base32):
#   node -e "console.log(require('crypto').randomBytes(20).toString('hex'))"
# Or generate Base32 directly:
#   node -e "const a='ABCDEFGHIJKLMNOPQRSTUVWXYZ234567',b=require('crypto').randomBytes(20);let r='';for(let i=0;i<32;i++)r+=a[((b[Math.floor(i*5/8)]<<8|b[Math.floor(i*5/8+1)])>>>(15-(i*5)%8))&31];console.log(r)"

CRON_SECRET=replace-with-a-long-random-secret
# Used for: Bearer token in Vercel Cron Job auth (proxy.ts)
# Must match the value configured in Vercel Cron Jobs UI / vercel.json

PIN_ENCRYPTION_KEY=replace-with-32-byte-hex-key-0123456789abcdef0123456789abcdef
# Used for: AES-256-GCM PIN encryption/decryption
# WARNING: Generate a UNIQUE key for each environment. Do NOT reuse.
# Must be exactly 32 bytes (64 hex characters)

OTP_PEPPER_SECRET=replace-with-another-long-random-secret
# Used for: OTP hashing (separate from ADMIN_SECRET)

# ── Admin Contact ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_NAME=MeraDarzi Admin
NEXT_PUBLIC_ADMIN_WHATSAPP=920000000000
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# ── Timezone ──────────────────────────────────────────────────────────────────
TIMEZONE=Asia/Karachi
# Used for: Server-side date calculations

# ── Cloudinary (image hosting) ────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Raast (Pakistan Instant Payment) ──────────────────────────────────────────
NEXT_PUBLIC_RAAST_ID=03000000000
NEXT_PUBLIC_RAAST_NAME=Your Name
NEXT_PUBLIC_RAAST_BANK=Your Bank

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
# Get from: https://resend.com/api-keys

RESEND_FROM_EMAIL=no-reply@example.com
# Must be a verified domain in Resend

# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
# Get from: Upstash Console → Redis Database → REST API

UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# Get from: Upstash Console → Redis Database → REST API

# ── Web Push (VAPID for browser notifications) ────────────────────────────────
# Generate fresh keys for each environment:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-your-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com
