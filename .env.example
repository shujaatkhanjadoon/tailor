# Supabase Database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
TIMEZONE=Asia/Karachi

# Admin
ADMIN_SECRET=replace-with-a-long-random-secret
ADMIN_TOTP_SECRET=replace-with-your-totp-secret
NEXT_PUBLIC_ADMIN_NAME=MeraDarzi Admin
NEXT_PUBLIC_ADMIN_WHATSAPP=920000000000
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Cron
CRON_SECRET=replace-with-a-long-random-secret

# Cloudinary (optional)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Raast
NEXT_PUBLIC_RAAST_ID=03000000000
NEXT_PUBLIC_RAAST_NAME=Your Name
NEXT_PUBLIC_RAAST_BANK=Your Bank

# Email OTP via Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@example.com

# Rate Limiting via Upstash
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

