{
  "regions": ["bom1"],
  "functions": {
    "api/cron/*": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/expire-subscriptions",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/reset-usage",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/cleanup-photos",
      "schedule": "0 3 * * *"
    }
  ]
}
